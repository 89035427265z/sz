# =============================================================================
# KARI.Самозанятые — Шаблон настроек окружения
# =============================================================================
# ИНСТРУКЦИЯ:
#   1. Скопируйте этот файл: cp .env.example .env
#   2. Заполните все значения
#   3. НИКОГДА не добавляйте .env в git (он уже в .gitignore)
# =============================================================================


# =============================================================================
# БАЗА ДАННЫХ PostgreSQL
# =============================================================================
# Формат: postgresql+asyncpg://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
DATABASE_URL=postgresql+asyncpg://kari:ВАШ_ПАРОЛЬ@localhost:5432/kari_samozanyatye


# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0


# =============================================================================
# БЕЗОПАСНОСТЬ
# Сгенерировать SECRET_KEY: openssl rand -hex 32
# =============================================================================
SECRET_KEY=СГЕНЕРИРУЙТЕ_СЛУЧАЙНЫЙ_КЛЮЧ_32_СИМВОЛА
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# ШИФРОВАНИЕ ПЕРСОНАЛЬНЫХ ДАННЫХ (AES-256-GCM)
# Сгенерировать: openssl rand -hex 32
# Используется в services/crypto_service.py для паспортов и банковских реквизитов
# ОБЯЗАТЕЛЬНО для v2 — без этого crypto_service.py не запустится
# =============================================================================
ENCRYPTION_KEY=СГЕНЕРИРУЙТЕ_СЛУЧАЙНЫЙ_КЛЮЧ_32_СИМВОЛА


# =============================================================================
# SMS-СЕРВИС (SMSC.ru или аналог)
# =============================================================================
SMS_API_URL=https://smsc.ru/sys/send.php
SMS_API_KEY=ВАШ_КЛЮЧ_SMSC
SMS_SENDER=KARI
SMS_CODE_EXPIRE_MINUTES=5


# =============================================================================
# ФНС "МОЙ НАЛОГ"
# Получить доступ: https://api.nalog.ru (для партнёров)
# =============================================================================
FNS_API_URL=https://api.nalog.ru/rnt/ais3/npd/v1
FNS_SOURCE_DEVICE_ID=ВАШ_DEVICE_ID_ОТ_ФНС
FNS_APP_VERSION=1.0.0
FNS_INN_KARI=ИНН_КОМПАНИИ_KARI


# =============================================================================
# СОВКОМБАНК (выплаты самозанятым)
# Получить в личном кабинете Совкомбанка для бизнеса
# =============================================================================
SOVCOMBANK_API_URL=https://api.sovcombank.ru/v1
SOVCOMBANK_API_KEY=ВАШ_API_КЛЮЧ
SOVCOMBANK_ACCOUNT_NUMBER=РАСЧЕТНЫЙ_СЧЕТ_KARI
SOVCOMBANK_BIK=043469743


# =============================================================================
# MinIO (хранение фотоотчётов и документов)
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=ИЗМЕНИТЕ_ПАРОЛЬ_MINIO
MINIO_BUCKET_PHOTOS=kari-photos
MINIO_BUCKET_DOCS=kari-documents
MINIO_SECURE=false


# =============================================================================
# FIREBASE (push-уведомления)
# Скачать из Firebase Console → Project Settings → Service accounts
# =============================================================================
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json


# =============================================================================
# ОБЩИЕ НАСТРОЙКИ
# =============================================================================
APP_VERSION=1.0.0
DEBUG=true
# При разработке — разрешаем все origins. На проде — только домен KARI!
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Секретная фраза для создания первого директора региона (POST /users/init)
# Придумайте свою — нужна один раз при первом запуске системы
INIT_SECRET=KARI_INIT_2025
